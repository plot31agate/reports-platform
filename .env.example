# Copy to .env on the server and fill in real values. Never commit .env.

# App
APP_ENV=production
APP_URL=https://reports.digital-footprints.co.uk
SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-32
SESSION_MAX_AGE_SECONDS=86400

# Admin login (change on first deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=change-me-run-scripts-hash-password.py

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_SENTIMENT=claude-haiku-4-5
CLAUDE_MODEL_SYNTHESIS=claude-sonnet-4-6

# Paths (defaults are fine)
DATA_DIR=/home/wwwdfootdigi/apps/reporting/data
REPORTS_OUT_DIR=/home/wwwdfootdigi/apps/reporting/reports_out
DB_PATH=/home/wwwdfootdigi/apps/reporting/reporting.db

# PDF engine. "auto" uses Chromium when found (pixel-identical to the web
# report), otherwise falls back to WeasyPrint. On AlmaLinux 8:
#   sudo dnf install -y epel-release && sudo dnf install -y chromium-headless
# then point CHROMIUM_BINARY at the headless shell and restart the service.
PDF_ENGINE=auto
CHROMIUM_BINARY=/usr/lib64/chromium-browser/headless_shell
